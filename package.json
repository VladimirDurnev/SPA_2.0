{
  "name": "spa2-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "core",
    "core/storybook"
  ],
  "scripts": {
    "dev:operator": "npm run -w app-operator dev",
    "dev:admin": "npm run -w app-admin dev",
    "dev:expert": "npm run -w app-expert dev",
    "build": "npm run -w @org/core build && npm run -w app-operator -w app-admin -w app-expert build",
    "build:analyze": "npm run -w @org/core build && npm run build:analyze:operator && npm run build:analyze:admin && npm run build:analyze:expert",
    "build:analyze:operator": "npm run -w app-operator build -- --mode analyze",
    "build:analyze:admin": "npm run -w app-admin build -- --mode analyze",
    "build:analyze:expert": "npm run -w app-expert build -- --mode analyze",
    "docs:fstek": "node scripts/build-fstek-docx.cjs",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:generate:operator": "tsx scripts/generate-openapi.ts operator",
    "openapi:generate:admin": "tsx scripts/generate-openapi.ts admin",
    "openapi:generate:expert": "tsx scripts/generate-openapi.ts expert",
    "swagger:ui": "node scripts/serve-swagger.mjs",
    "swagger:build": "node scripts/build-swagger.mjs",
    "lint": "eslint .",
    "lint:apps-imports": "eslint -c eslint.imports-only.config.mjs \"apps/*/src/**/*.{ts,tsx}\"",
    "lint:styles": "stylelint \"**/*.{css,scss,less,styled.ts,styled.tsx}\"",
    "mock:server": "node mock/server.cjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:html": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html",
    "test:coverage:open": "node scripts/open-coverage.cjs",
    "test:coverage:check": "vitest run --coverage --coverage.thresholds.lines=80 --coverage.thresholds.functions=80 --coverage.thresholds.branches=80 --coverage.thresholds.statements=80",
    "test:e2e": "playwright test",
    "test:e2e:update": "node scripts/e2e-update.cjs all",
    "test:e2e:update:screens": "node scripts/e2e-update.cjs screens",
    "test:e2e:install": "playwright install",
    "test:e2e:ui": "playwright test --ui --ui-host=127.0.0.1",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:storybook": "npm run storybook:build",
    "storybook": "npm run -w @org/core-storybook dev",
    "storybook:build": "npm run -w @org/core-storybook build",
    "add:root": "npm i",
    "add:core": "npm i -w @org/core",
    "add:platform": "npm i -w @org/core",
    "add:operator": "npm i -w app-operator",
    "add:admin": "npm i -w app-admin",
    "add:expert": "npm i -w app-expert",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.0.0",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@playwright/test": "^1.53.0",
    "@storybook/react-vite": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.0",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "json-server": "^0.17.4",
    "lint-staged": "^16.0.0",
    "postcss-styled-syntax": "^0.7.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^37.0.0",
    "swagger-ui-dist": "^5.32.6",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@reduxjs/toolkit": "^2.2.0",
    "antd": "^5.0.0",
    "axios": "^1.7.0",
    "d3": "^7.9.0",
    "dayjs": "^1.11.0",
    "i18next": "^25.0.0",
    "jspdf": "4.2.1",
    "jszip": "^3.10.0",
    "lodash": "^4.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "react-redux": "^9.1.0",
    "react-router": "^7.0.0",
    "styled-components": "^6.1.0",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
